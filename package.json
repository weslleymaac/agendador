{
  "name": "agendador",
  "version": "1.0.0",
  "description": "API de agendamento com BullMQ para disparo de webhooks",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "concurrently -n next,api -c cyan,magenta \"npm run dev:next\" \"cross-env PROXY_NEXT_DEV=1 node --watch src/index.js\"",
    "dev:api": "node --watch src/index.js",
    "dev:next": "npm run dev --prefix frontend -- -p 3001",
    "dev:front": "npm run dev:next",
    "dev:split": "concurrently -n next,api -c cyan,magenta \"npm run dev:next\" \"npm run dev:api\"",
    "dev:all": "npm run dev",
    "build:front": "npm run build --prefix frontend",
    "start:front": "npm run start --prefix frontend -- -p 3001",
    "redis:up": "docker compose up -d redis",
    "redis:down": "docker compose down",
    "redis:logs": "docker compose logs -f redis"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "bullmq": "^5.70.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.3.1",
    "http-proxy-middleware": "^3.0.3",
    "ioredis": "^5.10.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3"
  }
}
