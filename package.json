{
  "name": "agendador",
  "version": "1.0.0",
  "description": "API de agendamento com BullMQ para disparo de webhooks",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "redis:up": "docker compose up -d redis",
    "redis:down": "docker compose down",
    "redis:logs": "docker compose logs -f redis"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "bullmq": "^5.70.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.3.1",
    "ioredis": "^5.10.0",
    "uuid": "^13.0.0"
  }
}
