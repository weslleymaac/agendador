PORT=3000
REDIS_URL=redis://localhost:6379

# EasyPanel: as variáveis de produção vêm do docker-compose.easypanel.yml (ou do painel).
# No Docker, NÃO defina VERCEL para que o worker BullMQ suba junto da API.

# Fuso horário para interpretar data/hora do agendamento (horas em relação ao UTC; padrão -3 = Brasília).
# Em produção (EasyPanel, VPS, etc.), defina APP_TIMEZONE_OFFSET=-3 para horário de Brasília.
APP_TIMEZONE_OFFSET=-3

# CORS: origem permitida (ex: https://meuapp.com) ou deixe vazio para refletir a origem da requisição
# CORS_ORIGIN=

# Opcional: proteção do endpoint /api/cron-process-jobs (EasyPanel com serviço cron).
# Se definido, o cron deve enviar header x-cron-secret ou query secret com o mesmo valor.
# CRON_SECRET=

# Opcional: em vez de REDIS_URL, use:
# REDIS_HOST=localhost
# REDIS_PORT=6379
