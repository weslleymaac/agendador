PORT=3000
# Opcional: porta interna do Next em `npm run dev` (default 3001). O script ativa o proxy na API automaticamente.
# NEXT_DEV_PROXY_TARGET=http://127.0.0.1:3001
APP_TIMEZONE_OFFSET=-3

# Redis: use REDIS_URL (recomendado para servidor externo) OU deixe vazio e preencha porta/usuário/senha (host padrão: localhost).
# TLS: rediss://usuario:senha@host:6379
REDIS_URL=
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=

# Opcional se REDIS_URL estiver vazio e o Redis não for local:
# REDIS_HOST=127.0.0.1

LOGIN_USERNAME=Admin
LOGIN_PASSWORD=admin

# Dev: URL da API (Express). Com Express na 3000 e Next na 3001, use http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# Docker (EasyPanel) — imagem única (Dockerfile raiz): não defina NEXT_PUBLIC_API_BASE_URL como localhost.
# Deixe vazio no build ou omita; o browser usa a mesma origem (Express na 3000).
