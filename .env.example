PORT=3000
REDIS_URL=redis://localhost:6379

# Fuso horário para interpretar data/hora do agendamento (horas em relação ao UTC; padrão -3 = Brasília).
# No Vercel defina APP_TIMEZONE_OFFSET=-3 para que o horário seja em UTC-3 (Brasília).
APP_TIMEZONE_OFFSET=-3

# CORS: origem permitida (ex: https://meuapp.com) ou deixe vazio para refletir a origem da requisição
# CORS_ORIGIN=

# Opcional: em vez de REDIS_URL, use:
# REDIS_HOST=localhost
# REDIS_PORT=6379
